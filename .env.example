# ── Apollo.io ─────────────────────────────────────────────────────────────────
APOLLO_API_KEY=your_apollo_api_key_here

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail (your work email) ───────────────────────────────────────────────────
# Follow README to generate credentials.json via Google Cloud Console
GMAIL_SENDER_ADDRESS=you@yourcompany.com
GMAIL_CREDENTIALS_PATH=credentials/credentials.json
GMAIL_TOKEN_PATH=credentials/token.json

# ── You ───────────────────────────────────────────────────────────────────────
YOUR_NAME=Jaspal Singh
YOUR_TITLE=Director of Revenue Operations
YOUR_COMPANY=YourCompany
YOUR_CALENDLY_LINK=https://calendly.com/yourlink
DIGEST_EMAIL_RECIPIENT=you@yourcompany.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=localhost
APP_PORT=8000
SECRET_TOKEN=change-this-to-a-random-string

# ── Targeting ─────────────────────────────────────────────────────────────────
# Comma-separated list of industries to target (Apollo industry names)
TARGET_INDUSTRIES=Construction,Consulting,Staffing and Recruiting,Oil and Gas,Financial Services,Information Technology and Services,Computer Software,Management Consulting

# Minimum employee count
MIN_EMPLOYEES=20

# Max accounts per weekly batch
ACCOUNTS_PER_WEEK=50
